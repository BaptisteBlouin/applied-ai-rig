{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BaptisteBlouin/applied-ai-rig/schemas/manifest.schema.json",
  "title": "Applied AI Rig installation manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rig_version",
    "installed_at",
    "selected_modules",
    "files",
    "manual_integrations"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "rig_version": {
      "type": "string",
      "minLength": 1
    },
    "installed_at": {
      "type": "string",
      "minLength": 1
    },
    "selected_modules": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/moduleId"
      }
    },
    "files": {
      "type": "array",
      "uniqueItems": true,
      "$comment": "File paths must also be unique across entries; Manifest enforces that cross-item invariant at runtime.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "original_checksum"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "not": {
              "pattern": "(^/|^[A-Za-z]:|(^|/)\\.\\.(/|$)|\\\\)"
            }
          },
          "original_checksum": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "manual_integrations": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "not": {
          "pattern": "(^/|^[A-Za-z]:|(^|/)\\.\\.(/|$)|\\\\)"
        }
      }
    },
    "manual_integration_statuses": {
      "type": "object",
      "$comment": "When present, keys must exactly match manual_integrations; Manifest enforces this cross-property invariant at runtime.",
      "additionalProperties": {
        "enum": ["proposed", "accepted", "declined", "completed"]
      }
    }
  },
  "$defs": {
    "moduleId": {
      "enum": [
        "model-api",
        "data",
        "evaluation",
        "agentic-runtime",
        "operations"
      ]
    }
  }
}
